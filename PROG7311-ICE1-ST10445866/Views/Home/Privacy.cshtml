@{
    ViewData["Title"] = "Privacy & Data Policy";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <h1 class="display-5 fw-bold text-primary mb-4"><i class="bi bi-shield-lock-fill me-2"></i>Privacy Policy</h1>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold">1. Data Collection Statement</h5>
                <p class="text-muted">
                    This portfolio is a demonstration of technical proficiency. When you use the <strong>"Request Document Access"</strong> or <strong>"Contact Me"</strong> features, the information provided (such as your email address) is used solely for the purpose of fulfilling that specific request.
                </p>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold">2. POPIA Compliance</h5>
                <p class="text-muted">
                    In accordance with the <em>Protection of Personal Information Act (POPIA)</em>, I am committed to protecting your personal data. No information collected through this application is shared with third parties, sold, or used for marketing purposes without your explicit consent.
                </p>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold">3. Technical Security</h5>
                <p class="text-muted">
                    As an Application Development student, I implement security best practices in my code to prevent unauthorized access to the data transmitted through this web application.
                </p>
            </div>

            <div class="mt-5">
                <a asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Portfolio
                </a>
            </div>
        </div>
    </div>
</div>